  "keyFeatures": [
    "Notes with markdown, wikilinks, and #hashtag tagging",
    "Todo management with priorities, due dates, and status tracking",
    "Pomodoro-style focus timer with session history",
    "Local semantic search with ONNX embeddings",
    "Bidirectional linking between notes and todos",
    "Visual mind map of note connections",
    "Quick capture (Ctrl+X) from anywhere",
    "100% local - no cloud dependencies"
  ],
  "publicApiSurface": [
    "flowstate - Main CLI command",
    "Notes Screen (Ctrl+N) - Create, edit, preview, delete notes",
    "Todos Screen (Ctrl+T) - Manage tasks with priorities and due dates",
    "Focus Screen (Ctrl+F) - Pomodoro timer with breaks",
    "Search Screen (Ctrl+/) - Semantic search across notes",
    "Mind Map Screen (Ctrl+G) - Visual graph navigation",
    "Quick Capture (Ctrl+X) - Instant note creation",
    "Linking Modal (Ctrl+L) - Create relationships between items"
  ]
